# Environment variables for local development and production

# Sanity Configuration
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-15
SANITY_API_TOKEN=your_api_token_here

# Revalidation webhook (shared secret between Sanity webhook and this app)
REVALIDATION_SECRET=your_revalidation_secret_here

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# SendGrid (contact form)
SENDGRID_API_KEY=your_sendgrid_api_key_here
CONTACT_TO_EMAIL=gabrielaabinajm@gmail.com
CONTACT_FROM_EMAIL=noreply@gabinajm.com

# Password-protected projects (HMAC signing key for access cookies)
PROJECT_ACCESS_SECRET=your_random_secret_here

# Optional: Image optimization
NEXT_PUBLIC_IMAGE_OPTIMIZATION_ENABLED=true
